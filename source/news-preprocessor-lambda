def read_raw_file(bucket_name, raw_key, collect_date_yyyymmdd):
    response = s3.get_object(Bucket=bucket_name, Key=raw_key)
    raw_content = response["Body"].read()
    source_name = get_source_name_from_key(raw_key)

    raw_data = json.loads(raw_content.decode("utf-8"))

    return parse_collector_json(raw_data, source_name, collect_date_yyyymmdd)


def merge_dedup_items(items):
    dedup_dict = {}

    for item in items:
        key = (
            item.get("dedup_key")
            or item.get("originallink")
            or item.get("link")
            or item.get("title")
        )

        if not key:
            continue

        dedup_dict[key] = item

    final_items = list(dedup_dict.values())

    final_items.sort(
        key=lambda x: x.get("pubDate_dt", ""),
        reverse=True
    )

    return final_items


def save_processed_for_collection_date(bucket_name, yyyymmdd, items):
    """
    processed 파일명은 반드시 raw 수집 날짜 기준으로 생성한다.
    """
    processed_base = (
        f"{PREFIX}/"
        f"{CATEGORY_FOLDER}/"
        f"processed/"
        f"news_final_{yyyymmdd}"
    )

    final_json_key = f"{processed_base}.json"
    final_csv_key = f"{processed_base}.csv"

    final_items = merge_dedup_items(items)

    save_json(bucket_name, final_json_key, final_items)
    save_csv(bucket_name, final_csv_key, final_items)

    return {
        "date": yyyymmdd,
        "json_file": final_json_key,
        "csv_file": final_csv_key,
        "total_unique_items": len(final_items)
    }


def rebuild_one_raw_date(bucket_name, target_date):
    """
    raw/{YYYY/MM/DD}/ 아래 전체 json을 읽고,
    raw 수집 날짜 기준으로 processed/news_final_YYYYMMDD 파일 하나를 생성한다.
    """
    raw_targets = list_raw_json_keys_for_date(bucket_name, target_date)
    raw_targets = raw_targets[:MAX_RAW_FILES_PER_RUN]

    print(f"[{target_date}] raw json files to process: {len(raw_targets)}")

    all_items_for_target_date = []
    parsed_item_count = 0
    error_count = 0
    errors = []

    for target in raw_targets:
        try:
            parsed_items = read_raw_file(
                target["bucket"],
                target["key"],
                collect_date_yyyymmdd=target_date
            )
            parsed_item_count += len(parsed_items)
            all_items_for_target_date.extend(parsed_items)

        except Exception as e:
            error_count += 1
            error_info = {
                "raw_key": target["key"],
                "message": str(e)
            }
            errors.append(error_info)
            print(json.dumps(error_info, ensure_ascii=False))

    saved_result = save_processed_for_collection_date(
        bucket_name,
        target_date,
        all_items_for_target_date
    )

    return {
        "target_date": target_date,
        "raw_file_count": len(raw_targets),
        "parsed_it_item_count_before_dedup": parsed_item_count,
        "created_processed_files": [saved_result],
        "error_count": error_count,
        "errors": errors[:20]
    }


def invoke_next_date_async(function_name, bucket_name, start_date, next_date, end_date):
    payload = {
        "mode": "batch_chain",
        "bucket": bucket_name,
        "start_date": start_date,
        "target_date": next_date,
        "end_date": end_date
    }

    lambda_client.invoke(
        FunctionName=function_name,
        InvocationType="Event",
        Payload=json.dumps(payload).encode("utf-8")
    )


def process_s3_event_files(raw_targets):
    """
    실시간 S3 ObjectCreated 이벤트용.
    새 raw 파일이 들어오면 raw 수집 날짜 기준 processed 파일에 merge.
    """
    results = []

    for target in raw_targets:
        bucket_name = target["bucket"]
        raw_key = target["key"]
        collect_date = extract_collect_date_from_raw_key(raw_key)

        parsed_items = read_raw_file(bucket_name, raw_key, collect_date)

        if not parsed_items:
            results.append({
                "raw_key": raw_key,
                "status": "skipped",
                "message": "No valid IT items parsed"
            })
            continue

        processed_base = (
            f"{PREFIX}/"
            f"{CATEGORY_FOLDER}/"
            f"processed/"
            f"news_final_{collect_date}"
        )

        final_json_key = f"{processed_base}.json"
        final_csv_key = f"{processed_base}.csv"

        try:
            response = s3.get_object(Bucket=bucket_name, Key=final_json_key)
            existing_items = json.loads(response["Body"].read().decode("utf-8"))
        except ClientError as e:
            if e.response["Error"]["Code"] == "NoSuchKey":
                existing_items = []
            else:
                raise e

        final_items = merge_dedup_items(existing_items + parsed_items)

        save_json(bucket_name, final_json_key, final_items)
        save_csv(bucket_name, final_csv_key, final_items)

        results.append({
            "raw_key": raw_key,
            "status": "processed",
            "collection_date": collect_date,
            "new_items": len(parsed_items),
            "total_unique_items": len(final_items),
            "json_file": final_json_key,
            "csv_file": final_csv_key
        })

    return results


