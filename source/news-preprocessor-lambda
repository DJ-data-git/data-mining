# 텍스트 정제
# =========================================================

def clean_html(text):
    if not text:
        return ""

    text = str(text)
    text = html.unescape(text)
    text = re.sub(r"<.*?>", " ", text)
    text = re.sub(r"\[.*?\]", " ", text)
    text = re.sub(r"\(.*?\)", " ", text)
    text = text.replace("'", "").replace('"', "").replace(",", " ")
    text = re.sub(r"&[a-zA-Z]+;", " ", text)
    text = re.sub(r"[^가-힣A-Za-z0-9\s./:%+-]", " ", text)
    text = re.sub(r"\s+", " ", text).strip()

    return text


def remove_stopwords(text):
    if not text:
        return ""

    tokens = re.findall(r"[가-힣A-Za-z0-9]+", text)
    cleaned = []

    for token in tokens:
        lower = token.lower()

        if lower in EN_STOPWORDS:
            continue
        if token in KO_STOPWORDS:
            continue
        if len(token) <= 1:
            continue

        cleaned.append(token)

    return " ".join(cleaned)


def find_it_keywords(text):
    """
    IT 키워드 매칭 함수.

    개선 사항:
    - "IT" 단독 키워드는 오탐이 너무 많아 IT_KEYWORDS에서 제거함.
    - AI, MS, DX, ICT, GPT, AWS 같은 짧은 영문 키워드는 단어 경계 기준으로만 매칭함.
      예: it / within / digital 같은 일반 영어 단어가 IT로 잘못 잡히는 문제 방지.
    - 한글/복합 키워드는 기존처럼 부분 포함 방식으로 매칭함.
    """
    if not text:
        return []

    matched = []
    lower_text = text.lower()

    for kw in IT_KEYWORDS:
        kw_str = str(kw).strip()
        if not kw_str:
            continue

        # 영문/숫자만 있는 키워드는 단어 경계 기준으로 매칭
        if re.fullmatch(r"[A-Za-z0-9.+#-]+", kw_str):
            pattern = rf"(?<![A-Za-z0-9]){re.escape(kw_str)}(?![A-Za-z0-9])"
            if re.search(pattern, text, flags=re.IGNORECASE):
                matched.append(kw_str)
        else:
            # 한글 또는 공백 포함 복합어는 기존 방식 유지
            if kw_str.lower() in lower_text:
                matched.append(kw_str)

    return sorted(set(matched))


def detect_event_tag(text):
    lower_text = text.lower()
    tags = []

    for kw, tag in EVENT_KEYWORDS.items():
        if kw.lower() in lower_text:
            tags.append(tag)

    return ", ".join(sorted(set(tags)))


# =========================================================
# 날짜 처리
# =========================================================

def normalize_yyyymmdd(value):
    return str(value).replace("-", "")


def today_yyyymmdd():
    return datetime.now(KST).strftime("%Y%m%d")


def next_yyyymmdd(yyyymmdd):
    dt = datetime.strptime(yyyymmdd, "%Y%m%d").date()
    return (dt + timedelta(days=1)).strftime("%Y%m%d")


def format_pubdate_dt(date_str):
    """
    기사 원문 pubDate를 KST datetime 문자열로 변환.
    단, processed 파일명은 이 날짜가 아니라 raw 폴더 날짜 기준으로 생성한다.
    """
    try:
        dt = parsedate_to_datetime(date_str)

        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=KST)

        dt = dt.astimezone(KST)

        return dt.strftime("%Y-%m-%d %H:%M:%S")

    except Exception:
        return ""


def normalize_pubdate_dt(item):
    if item.get("pubDate_dt"):
        return item.get("pubDate_dt")

    if item.get("pubDate"):
        return format_pubdate_dt(item.get("pubDate"))

    if item.get("pubDate_ymd"):
        try:
            dt = datetime.strptime(item.get("pubDate_ymd"), "%Y-%m-%d")
            dt = dt.replace(tzinfo=KST)
            return dt.strftime("%Y-%m-%d %H:%M:%S")
        except Exception:
            return ""

    return ""


def yyyymmdd_to_raw_date_path(yyyymmdd):
    return f"{yyyymmdd[0:4]}/{yyyymmdd[4:6]}/{yyyymmdd[6:8]}"


def yyyymmdd_to_date_str(yyyymmdd):
    return f"{yyyymmdd[0:4]}-{yyyymmdd[4:6]}-{yyyymmdd[6:8]}"


