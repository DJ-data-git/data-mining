def compact_item_for_output(item):
    """
    Streamlit 분석에 필요한 컬럼만 저장해 S3 파일 크기를 줄인다.
    dedup_key, clean_text, matched_it_keywords 등은 처리 중에만 사용하고 저장하지 않는다.
    """
    output_columns = [
        "source",
        "source_group",
        "title",
        "description",
        "originallink",
        "link",
        "pubDate_dt",
        "pubDate_ymd",
        "analysis_date",
        "event_tag"
    ]

    return {col: item.get(col, "") for col in output_columns}


def save_json(bucket_name, key, items):
    compact_items = [compact_item_for_output(item) for item in items]

    s3.put_object(
        Bucket=bucket_name,
        Key=key,
        Body=json.dumps(compact_items, ensure_ascii=False, indent=2).encode("utf-8"),
        ContentType="application/json; charset=utf-8"
    )


def save_csv(bucket_name, key, items):
    output = io.StringIO()
    writer = csv.writer(output)

    # Streamlit 대시보드에서 실제 사용하는 컬럼 중심으로 최소화
    # - source/source_group/title/description/originallink/link: 기사 표시 및 소스 분석
    # - pubDate_dt/pubDate_ymd/analysis_date: 날짜/시기별 분석
    # - event_tag: 이벤트성 기사 확인용 보조 컬럼
    columns = [
        "source",
        "source_group",
        "title",
        "description",
        "originallink",
        "link",
        "pubDate_dt",
        "pubDate_ymd",
        "analysis_date",
        "event_tag"
    ]

    writer.writerow(columns)

    for item in items:
        writer.writerow([item.get(col, "") for col in columns])

    s3.put_object(
        Bucket=bucket_name,
        Key=key,
        Body=output.getvalue().encode("utf-8-sig"),
        ContentType="text/csv; charset=utf-8"
    )


def list_raw_json_keys_for_date(bucket_name, yyyymmdd):
    date_path = yyyymmdd_to_raw_date_path(yyyymmdd)

    raw_prefix = (
        f"{PREFIX}/"
        f"{CATEGORY_FOLDER}/"
        f"raw/"
        f"{date_path}/"
    )

    keys = []
    token = None

    while True:
        params = {
            "Bucket": bucket_name,
            "Prefix": raw_prefix
        }

        if token:
            params["ContinuationToken"] = token

        response = s3.list_objects_v2(**params)

        for obj in response.get("Contents", []):
            key = obj["Key"]

            if key.endswith(".json"):
                keys.append({
                    "bucket": bucket_name,
                    "key": key
                })

        if not response.get("IsTruncated"):
            break

        token = response.get("NextContinuationToken")

    return sorted(keys, key=lambda x: x["key"])


def get_raw_keys_from_s3_event(event):
    keys = []

    for record in event.get("Records", []):
        bucket_name = record["s3"]["bucket"]["name"]
        raw_key = urllib.parse.unquote_plus(record["s3"]["object"]["key"])

        if (
            raw_key.startswith(f"{PREFIX}/{CATEGORY_FOLDER}/raw/")
            and raw_key.endswith(".json")
        ):
            keys.append({
                "bucket": bucket_name,
                "key": raw_key
            })

    return keys


def extract_collect_date_from_raw_key(raw_key):
    """
    raw key 예:
    it_news/IT/raw/2026/05/14/15/all_20260514_150000.json
    → 20260514
    """
    pattern = rf"{PREFIX}/{CATEGORY_FOLDER}/raw/(\d{{4}})/(\d{{2}})/(\d{{2}})/"
    m = re.search(pattern, raw_key)

    if not m:
        return today_yyyymmdd()

    return f"{m.group(1)}{m.group(2)}{m.group(3)}"


