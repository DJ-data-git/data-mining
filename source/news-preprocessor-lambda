def lambda_handler(event, context):
    print("Received event:")
    print(json.dumps(event, ensure_ascii=False))

    bucket_name = event.get("bucket") or BUCKET_NAME

    if not bucket_name:
        return {
            "statusCode": 400,
            "message": "Bucket name is missing. Set BUCKET_NAME env or pass bucket in event."
        }

    raw_targets = get_raw_keys_from_s3_event(event)

    mode = event.get("mode", "manual_start")

    # S3 ObjectCreated 이벤트는 실시간 머지 처리
    if raw_targets and mode != "batch_chain":
        results = process_s3_event_files(raw_targets)

        return {
            "statusCode": 200,
            "message": "S3 event preprocessing completed by raw collection date",
            "mode": "s3_event",
            "target_count": len(raw_targets),
            "results": results
        }

    # 수동 실행 {} 인 경우 무조건 20260514부터 오늘까지 하루씩 체인 처리
    start_date = normalize_yyyymmdd(event.get("start_date", DEFAULT_START_DATE))
    end_date = normalize_yyyymmdd(event.get("end_date", today_yyyymmdd()))

    if mode == "batch_chain" and event.get("target_date"):
        target_date = normalize_yyyymmdd(event.get("target_date"))
    else:
        target_date = start_date

    result = rebuild_one_raw_date(bucket_name, target_date)

    next_date = next_yyyymmdd(target_date)
    has_next = next_date <= end_date

    invoked_next = False

    if has_next:
        function_name = SELF_FUNCTION_NAME or context.function_name

        invoke_next_date_async(
            function_name=function_name,
            bucket_name=bucket_name,
            start_date=start_date,
            next_date=next_date,
            end_date=end_date
        )

        invoked_next = True

    return {
        "statusCode": 200,
        "message": "One raw collection date processed. Next date invoked asynchronously." if invoked_next else "Batch chain completed.",
        "mode": mode,
        "basis": "raw_collection_date",
        "start_date": start_date,
        "target_date": target_date,
        "end_date": end_date,
        "next_date": next_date if has_next else None,
        "invoked_next": invoked_next,
        **result
    }
