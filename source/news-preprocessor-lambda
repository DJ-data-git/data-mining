def get_source_name_from_key(raw_key):
    filename = raw_key.split("/")[-1]

    if filename.startswith("google_"):
        parts = filename.split("_")

        if len(parts) >= 2:
            return f"{parts[0]}_{parts[1]}"

    return filename.split("_")[0]


def parse_collector_json(raw_data, fallback_source, collect_date_yyyymmdd):
    """
    raw JSON 안의 기사를 파싱한다.
    핵심:
    - 기사 원문 pubDate는 pubDate_dt로 보존
    - 분석 기준 날짜/파일 생성 날짜는 raw 폴더 날짜인 collect_date_yyyymmdd 사용
    """

    if isinstance(raw_data, dict):
        raw_items = raw_data.get("items", [])
    elif isinstance(raw_data, list):
        raw_items = raw_data
    else:
        raw_items = []

    items = []

    collect_date = yyyymmdd_to_date_str(collect_date_yyyymmdd)

    for item in raw_items:
        title = clean_html(item.get("title", ""))
        description = clean_html(item.get("description", ""))

        combined_text = f"{title} {description}".strip()
        clean_text_for_analysis = remove_stopwords(combined_text)

        matched_keywords = find_it_keywords(combined_text)

        # 비IT 기사는 processed 저장 대상에서 제외
        if not matched_keywords:
            continue

        # 원문 발행일은 참고용으로만 저장
        pubdate_dt = normalize_pubdate_dt(item)

        # pubDate가 없거나 이상해도 raw 수집 날짜를 기준으로 분석 가능하게 유지
        if not pubdate_dt:
            pubdate_dt = f"{collect_date} 00:00:00"

        originallink = item.get("originallink", "")
        link = item.get("link", "")

        source = item.get("source") or fallback_source
        source_group = item.get("source_group", "")
        media_domain = item.get("media_domain", "")

        dedup_key = (
            item.get("dedup_key")
            or originallink
            or link
            or f"{title}_{collect_date_yyyymmdd}_{media_domain}"
        )

        items.append({
            "source": source,
            "source_group": source_group,
            "media_domain": media_domain,
            "title": title,
            "originallink": originallink,
            "link": link,
            "description": description,
            "clean_text": clean_text_for_analysis,

            # 원문 기사 발행 시각
            "pubDate_dt": pubdate_dt,
            "pubDate_ymd": pubdate_dt[:10],

            # 대시보드/시기별 분석 기준 날짜: raw 수집 날짜
            "collection_date": collect_date,
            "analysis_date": collect_date,
            "analysis_hour": "",

            "is_it_news": True,
            "matched_it_keywords": ", ".join(matched_keywords),
            "event_tag": detect_event_tag(combined_text),
            "dedup_key": dedup_key
        })

    return items


